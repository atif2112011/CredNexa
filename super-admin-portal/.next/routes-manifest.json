{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/accounts/[accountId]",
      "regex": "^/accounts/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPaccountId": "nxtPaccountId"
      },
      "namedRegex": "^/accounts/(?<nxtPaccountId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/admin/[...path]",
      "regex": "^/api/admin/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPpath": "nxtPpath"
      },
      "namedRegex": "^/api/admin/(?<nxtPpath>.+?)(?:/)?$"
    },
    {
      "page": "/consent-versions/[id]",
      "regex": "^/consent\\-versions/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/consent\\-versions/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/devices/[deviceId]",
      "regex": "^/devices/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPdeviceId": "nxtPdeviceId"
      },
      "namedRegex": "^/devices/(?<nxtPdeviceId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/escalations/[caseId]",
      "regex": "^/escalations/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPcaseId": "nxtPcaseId"
      },
      "namedRegex": "^/escalations/(?<nxtPcaseId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/partners/[id]",
      "regex": "^/partners/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/partners/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/tenants/[id]",
      "regex": "^/tenants/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/tenants/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/accounts",
      "regex": "^/accounts(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/accounts(?:/)?$"
    },
    {
      "page": "/audit-logs",
      "regex": "^/audit\\-logs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/audit\\-logs(?:/)?$"
    },
    {
      "page": "/consent-versions",
      "regex": "^/consent\\-versions(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/consent\\-versions(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/devices",
      "regex": "^/devices(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/devices(?:/)?$"
    },
    {
      "page": "/escalations",
      "regex": "^/escalations(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/escalations(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/partners",
      "regex": "^/partners(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/partners(?:/)?$"
    },
    {
      "page": "/risk-flags",
      "regex": "^/risk\\-flags(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/risk\\-flags(?:/)?$"
    },
    {
      "page": "/tenants",
      "regex": "^/tenants(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/tenants(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}